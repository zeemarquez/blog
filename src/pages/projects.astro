---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Icon } from 'astro-icon/components'
import { projects } from '../data/projects'
---

<BaseLayout
	title="Projects — Zee Marquez"
	description="A selection of projects I've built — from engineering simulations to web apps."
>
	<main class="app-container pt-36">
		<h1 class="text-6xl pb-2 font-bold">Projects</h1>
		<p class="text-xl opacity-70 mt-4 max-w-2xl">
			A selection of things I've built. Most of the code lives on GitHub.
		</p>
	</main>

	<section class="app-container py-16 mb-8">
		<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
			{
				projects.map((project) => (
					<a
						href={project.url}
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col gap-4 p-6 rounded-xl border border-neutral-200 dark:border-neutral-800 hover:border-primary dark:hover:border-primary-dark transition-colors"
					>
						<div class="flex items-start justify-between gap-2">
							<h2 class="text-2xl font-semibold group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
								{project.title}
							</h2>
							<Icon
								name="mdi:arrow-top-right"
								size={20}
								class="shrink-0 mt-1 opacity-50 group-hover:opacity-100 transition-opacity"
							/>
						</div>
						<p class="opacity-80 text-base leading-relaxed grow">
							{project.description}
						</p>
						<div class="flex flex-wrap gap-2 mt-auto">
							{project.tags.map((tag) => (
								<span class="text-xs px-2 py-1 rounded-full bg-neutral-100 dark:bg-neutral-800 opacity-80">
									{tag}
								</span>
							))}
						</div>
						{project.year && (
							<p class="text-sm uppercase tracking-tight opacity-50">
								{project.year}
							</p>
						)}
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
