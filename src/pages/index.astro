---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_BASE, SocialLinks } from '../consts'
import { Icon } from 'astro-icon/components'
import { projects } from '../data/projects'
---

<BaseLayout>
	<main
		class="app-container flex flex-col gap-12 justify-center py-36 md:py-48 pt-44 md:pt-56 relative"
	>
		<div>
			<p class="block text-3xl opacity-70 mt-9 mb-4">Hi, I'm</p>
			<h1 class="text-8xl font-bold leading-none">Zee Marquez</h1>
		</div>
		<p class="text-2xl max-w-2xl font-light leading-normal">
			Renewable energy specialist combining asset engineering, data science, and project finance.
			I work across the full stack of a problem — from structural loads to financial models.
		</p>
		<div class="flex flex-wrap gap-8">
			{
				SocialLinks.map((link) => (
					<a
						class="text-xl text-primary dark:text-primary-dark underline hover:underline underline-offset-4"
						href={link.url}
						target="_blank"
					>
						{link.name}
					</a>
				))
			}
		</div>
	</main>

	<!-- Projects Section -->
	<section class="app-container pb-20">
		<h2 class="section-title">Projects</h2>
		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-6">
			{
				projects.map((project) => (
					<a
						href={`/projects/${project.slug}`}
						class="group flex flex-col rounded-2xl border border-neutral-200 dark:border-neutral-800 hover:border-primary dark:hover:border-primary-dark overflow-hidden transition-colors"
					>
						{/* Image slideshow */}
						<div
							class="relative overflow-hidden aspect-video bg-neutral-100 dark:bg-neutral-900"
							data-slideshow
						>
							{project.images.map((src, i) => (
								<img
									src={src}
									alt={`${project.title} screenshot ${i + 1}`}
									class="absolute inset-0 w-full h-full object-cover object-top transition-opacity duration-600"
									data-slide
									loading="lazy"
									style={i === 0 ? 'opacity:1' : 'opacity:0'}
								/>
							))}
							{project.images.length > 1 && (
								<div class="absolute bottom-2.5 left-0 right-0 flex justify-center gap-1.5 z-10">
									{project.images.map((_, i) => (
										<span
											class="block w-1.5 h-1.5 rounded-full bg-white/50 transition-all duration-300"
											data-dot={i}
											style={i === 0 ? 'background:rgba(255,255,255,0.95);transform:scale(1.3)' : ''}
										/>
									))}
								</div>
							)}
						</div>

						{/* Card body */}
						<div class="flex flex-col gap-3 p-5 grow">
							<div class="flex items-start justify-between gap-2">
								<div>
									<h3 class="text-xl font-semibold group-hover:text-primary dark:group-hover:text-primary-dark transition-colors leading-tight">
										{project.title}
									</h3>
									<p class="text-sm opacity-60 mt-0.5">{project.subtitle}</p>
								</div>
								<Icon
									name="mdi:arrow-top-right"
									size={18}
									class="shrink-0 mt-1 opacity-40 group-hover:opacity-100 transition-opacity"
								/>
							</div>
							<p class="text-sm opacity-75 leading-relaxed grow line-clamp-2">
								{project.description}
							</p>
							<div class="flex flex-wrap gap-1.5 mt-auto pt-1">
								{project.tags.slice(0, 3).map((tag) => (
									<span class="text-xs px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 opacity-80">
										{tag}
									</span>
								))}
							</div>
						</div>
					</a>
				))
			}
		</div>
		<a class="btn-secondary mt-8" href={`${SITE_BASE}/projects`}>
			All projects
			<Icon size={20} name="mdi:arrow-right" />
		</a>
	</section>

	<!-- About + Contact -->
	<section class="app-container py-16 grid lg:grid-cols-2 gap-20 lg:gap-10 border-t border-neutral-200 dark:border-neutral-800">
		<div class="space-y-6">
			<h2 class="section-title">About Me</h2>
			<p class="text-lg max-w-xl pb-4">
				Renewable energy specialist at the intersection of asset engineering, data science,
				and project finance. I've analysed solar and wind assets, built IoT platforms that
				cut OPEX, and reduced CAPEX by 10% on utility-scale wind towers.
			</p>
			<a class="btn-secondary" href={`${SITE_BASE}/about`}>
				More about me
				<Icon size={20} name="mdi:arrow-right" />
			</a>
		</div>
		<div class="space-y-6">
			<h2 class="section-title">Get in touch</h2>
			<p class="text-lg max-w-xl">
				Have a question, idea, or collaboration in mind? Feel free to reach out.
			</p>
			<div class="flex flex-wrap gap-3">
				<a
					class="btn-primary"
					href="mailto:zeemarquez@outlook.com"
					target="_blank"
				>
					Say hello
					<Icon height={20} name="mdi:email" />
				</a>
				<a
					class="btn-secondary"
					href="/cv/CV Zee Marquez.pdf"
					download
					target="_blank"
				>
					Download CV
					<Icon height={20} name="mdi:arrow-collapse-down" />
				</a>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	function initSlideshows() {
		document.querySelectorAll<HTMLElement>('[data-slideshow]').forEach((el) => {
			const slides = el.querySelectorAll<HTMLElement>('[data-slide]')
			const dots = el.querySelectorAll<HTMLElement>('[data-dot]')
			if (slides.length <= 1) return

			let current = 0

			function show(index: number) {
				slides[current].style.opacity = '0'
				if (dots[current]) {
					dots[current].style.background = 'rgba(255,255,255,0.5)'
					dots[current].style.transform = 'scale(1)'
				}
				current = index
				slides[current].style.opacity = '1'
				if (dots[current]) {
					dots[current].style.background = 'rgba(255,255,255,0.95)'
					dots[current].style.transform = 'scale(1.3)'
				}
			}

			let timer = setInterval(() => show((current + 1) % slides.length), 3000)
			el.addEventListener('mouseenter', () => clearInterval(timer))
			el.addEventListener('mouseleave', () => {
				timer = setInterval(() => show((current + 1) % slides.length), 3000)
			})
		})
	}

	initSlideshows()
	document.addEventListener('astro:page-load', initSlideshows)
</script>
